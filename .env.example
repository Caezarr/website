# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Site URL (used for sitemap, metadata)
NEXT_PUBLIC_SITE_URL=https://example.com

# Sanity write token (for seeding scripts, optional)
SANITY_API_WRITE_TOKEN=

# Google Tag Manager is configured in src/app/layout.tsx
